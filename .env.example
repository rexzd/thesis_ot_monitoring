# OT Monitoring - Example Environment Configuration
# Copy this file to .env and adjust values for your local environment.

# Target system profile
# Options today: simulator
# Future: abb_800xa, other adapters
OT_TARGET_PROFILE=simulator

# OPC UA connection
OPCUA_ENDPOINT=opc.tcp://localhost:4840/800xa/server/
OPCUA_ROOT_PATH=0:Objects,0:simulator

# Logical signal mapping (logical_name -> OPC UA child address)
SIGNAL_CONTROLLER_ADDRESS=0:controller_status
SIGNAL_COMMUNICATION_ADDRESS=0:communication_status
SIGNAL_ALARM_ADDRESS=0:alarm_active

# Experiment runtime configuration
EXPERIMENT_DURATION_SECONDS=15
POLL_INTERVAL_SECONDS=2
SUBSCRIPTION_PUBLISHING_INTERVAL_MS=500

# Output and analysis
RESULTS_DIR=results
ANALYSIS_SIGNAL_NAME=controller_status

# Optional behavior flags
# Use 1/0 for booleans in env files
LOG_TO_CONSOLE=1
